{
  "name": "Duker News",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; vite dev --port 3000 --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "SKIP_RESET=1 vitest run --config vitest.e2e.config.ts",
    "e2e:all": "vitest run --config vitest.e2e.config.ts",
    "e2e:boost": "SKIP_RESET=1 vitest run --config vitest.e2e.config.ts -t 'Boost'",
    "e2e:server": "vite dev --port 3000",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "gen:icons": "tsx scripts/gen-icons.ts",
    "cf-typegen": "wrangler types",
    "d1:truncate": "wrangler d1 execute duker-news-db --local --command \"DELETE FROM translations; DELETE FROM x402_triggered_cmds; DELETE FROM user_interactions; DELETE FROM events; DELETE FROM comments; DELETE FROM posts; DELETE FROM users; DELETE FROM sqlite_sequence;\"",
    "d1:migrate": "wrangler d1 execute duker-news-db --local --file=migrations/0000_schema.sql",
    "deploy": "VITE_DUKER_NEWS_CHAIN=xlayer pnpm run build && wrangler deploy",
    "fresh-deploy": "bash scripts/fresh-deploy.sh"
  },
  "dependencies": {
    "@alm/dao-bagua-diagram": "workspace:*",
    "@alm/dukernews-dao-contract": "workspace:*",
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@dagrejs/dagre": "^2.0.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@formkit/auto-animate": "^0.9.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@repo/dukernews-apidefs": "workspace:*",
    "@repo/dukiregistry-apidefs": "workspace:*",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.12.4",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@tanstack/router-plugin": "^1.132.0",
    "@types/dagre": "^0.7.54",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contract-duki-alm-world": "workspace:*",
    "idb": "^8.0.3",
    "jose": "^6.2.0",
    "kysely": "^0.28.9",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "siwe": "^3.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.3.6",
    "viem": "^2.45.2",
    "vite-tsconfig-paths": "^6.0.2",
    "wagmi": "^2.19.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@inlang/paraglide-js": "^2.8.0",
    "@playwright/test": "^1.58.2",
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^11.10.0",
    "country-locale-map": "^1.9.12",
    "jsdom": "^27.0.0",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.69.0"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "pnpm": {
    "overrides": {
      "wagmi": "2.x"
    }
  }
}