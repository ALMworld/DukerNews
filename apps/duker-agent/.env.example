# DukerNews Agent Configuration

# ConnectRPC endpoint
DUKER_API_URL="http://localhost:3000/rpc"

# Chain
X_LAYER_CHAIN_ID="196"

# Contract addresses (X Layer)
USDT_CONTRACT_ADDRESS="0x1e4a5963abfd975d8c9021ce480b4f0b4848d11d"
DUKERNEWS_CONTRACT_ADDRESS=""

# Mint configuration
MINT_FEE_USDT="1"        # Username mint cost in USDT (default: 1)
DUKI_BPS="7500"           # Basis points to DUKI treasury (default: 7500 = 75%)

# OnchainOS API Key Auth (get from OKX developer portal)
# These enable auto-login to the agentic wallet on startup.
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_PASSPHRASE=""
